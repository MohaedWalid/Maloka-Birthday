<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="#FAFAF8">
    <title>Happy Birthday Maloka</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold:#C9A84C; --gold-light:#E8C97A; --gold-pale:#F5EDD6;
            --ink:#1a1a1a; --muted:#8a8a8a; --bg:#FAFAF8; --white:#fff;
            --line:rgba(201,168,76,0.22);
        }
        *{margin:0;padding:0;box-sizing:border-box;}
        html{scroll-behavior:smooth;}
        body{background:var(--bg);color:var(--ink);font-family:'Jost',sans-serif;font-weight:300;overflow-x:hidden;}

        /* ══════════════════════════════
           STAGE 1: FIREWORK SHOW SCREEN
        ══════════════════════════════ */
        #fw-stage {
            position:fixed; inset:0; z-index:500;
            background:var(--bg);
            display:flex; align-items:center; justify-content:center;
            transition:opacity 1.2s ease;
        }
        #fw-stage.hide {
            opacity:0; pointer-events:none;
        }

        #fireworks-canvas {
            position:absolute; inset:0;
            z-index:1; pointer-events:none;
        }

        #fw-message {
            position:absolute; inset:0;
            z-index:2; pointer-events:none;
        }

        .fw-line {
            position:absolute; left:50%;
            transform:translateX(-50%);
            text-align:center;
            font-family:'Cormorant Garamond',serif;
            font-style:italic; font-weight:300;
            white-space:nowrap; opacity:0;
            letter-spacing:0.07em;
            text-shadow:0 0 40px rgba(201,168,76,0.45), 0 2px 16px rgba(0,0,0,0.1);
        }
        .fw-line.line-1{font-size:clamp(2rem,6vw,5.5rem);color:var(--gold);      top:25%;}
        .fw-line.line-2{font-size:clamp(1rem,3vw,2.6rem);color:var(--ink);       top:42%;}
        .fw-line.line-3{font-size:clamp(1rem,3vw,2.6rem);color:var(--ink);       top:52%;}
        .fw-line.line-4{font-size:clamp(1rem,3vw,2.6rem);color:var(--gold-light);top:62%;}

        @keyframes fwIn {
            0%  {opacity:0; transform:translateX(-50%) translateY(22px);}
            15% {opacity:1; transform:translateX(-50%) translateY(0);}
            78% {opacity:1; transform:translateX(-50%) translateY(0);}
            100%{opacity:0; transform:translateX(-50%) translateY(-16px);}
        }

        /* ══════════════════════════════
           SPLASH (before everything)
        ══════════════════════════════ */
        #splash {
            position:fixed; inset:0; z-index:1000; background:var(--bg);
            display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1.5rem;
            transition:opacity .8s ease, visibility .8s ease;
            padding:2rem;
        }
        #splash.hide{opacity:0;visibility:hidden;pointer-events:none;}
        #cake-svg   {width:clamp(120px,30vw,160px);height:clamp(120px,30vw,160px);}
        .plate      {opacity:0;animation:fadeIn .4s .1s  forwards;}
        .layer-bot  {opacity:0;animation:riseUp .5s .3s  forwards;}
        .layer-mid  {opacity:0;animation:riseUp .5s .55s forwards;}
        .layer-top  {opacity:0;animation:riseUp .5s .8s  forwards;}
        .candle     {opacity:0;animation:fadeIn .3s 1.1s forwards;}
        .flame      {opacity:0;transform-origin:50% 100%;animation:flameIn .4s 1.3s forwards;}
        .splash-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(1.5rem,5vw,2rem);color:var(--ink);opacity:0;animation:fadeUp .6s 1.5s forwards;letter-spacing:.08em;}
        .splash-sub  {font-size:clamp(.6rem,.5vw,.7rem);letter-spacing:.3em;color:var(--gold);text-transform:uppercase;opacity:0;animation:fadeUp .6s 1.7s forwards;}
        .splash-enter{margin-top:.5rem;font-size:clamp(.6rem,.5vw,.7rem);letter-spacing:.2em;color:var(--muted);text-transform:uppercase;cursor:pointer;border:none;background:none;font-family:'Jost',sans-serif;opacity:0;animation:fadeUp .6s 2s forwards;padding:.6rem 1.8rem;border-bottom:1px solid var(--line);transition:color .3s,border-color .3s;}
        .splash-enter:hover{color:var(--gold);border-color:var(--gold);}

        @keyframes riseUp {from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
        @keyframes fadeIn {from{opacity:0}to{opacity:1}}
        @keyframes fadeUp {from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
        @keyframes flameIn{from{opacity:0;transform:scaleY(0)}to{opacity:1;transform:scaleY(1)}}
        @keyframes flicker{0%,100%{transform:scaleY(1) scaleX(1)}40%{transform:scaleY(1.15) scaleX(.88)}70%{transform:scaleY(.9) scaleX(1.08)}}

        /* ══════════════════════════════
           STAGE 2: MAIN CONTENT
        ══════════════════════════════ */
        #main {
            opacity:0;
            transition:opacity 1.4s ease;
            position:relative; z-index:10;
        }
        #main.show { opacity:1; }

        .top-rule{width:100%;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);}
        .hero{position:relative;min-height:clamp(30vh,50vh,38vh);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:clamp(2rem,5vw,4rem) clamp(1rem,5vw,2rem) clamp(1rem,3vw,2rem);gap:.6rem;}
        h1{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:clamp(2.2rem,7vw,5.5rem);line-height:1;}
        h1 em{font-style:italic;color:var(--gold);}
        .hero-sub{font-size:clamp(.6rem,.5vw,.68rem);letter-spacing:.35em;color:var(--muted);text-transform:uppercase;}
        .divider-ornament{display:flex;align-items:center;gap:16px;margin:.5rem 0;opacity:.5;}
        .divider-ornament span{flex:1;height:1px;background:var(--gold);max-width:80px;}

        /* balloons (shown during main) */
        .balloons-layer{position:fixed;inset:0;z-index:20;pointer-events:none;overflow:hidden;opacity:0;transition:opacity 1s ease;}
        .balloons-layer.show{opacity:1;}
        .balloon{position:absolute;bottom:-160px;animation:balloonRise var(--dur) var(--dl) ease-in-out infinite;opacity:0;}
        .balloon svg{filter:drop-shadow(0 4px 12px rgba(0,0,0,0.12));}
        @keyframes balloonRise{
            0%  {transform:translateX(0) translateY(0);opacity:0;}
            5%  {opacity:.9;}
            45% {transform:translateX(var(--sway)) translateY(-55vh);opacity:.85;}
            90% {transform:translateX(calc(var(--sway)*-0.5)) translateY(-110vh);opacity:.4;}
            100%{transform:translateX(0) translateY(-120vh);opacity:0;}
        }

        /* 3D card */
        .card-section{padding:clamp(1.5rem,5vw,30px) clamp(1rem,5vw,20px) clamp(3rem,10vw,70px);display:flex;flex-direction:column;align-items:center;perspective:1200px;}
        .folder-container{position:relative;width:100%;max-width:clamp(280px,90vw,500px);height:clamp(350px,100vw,640px);cursor:pointer;transform-style:preserve-3d;}
        .folder-cover{position:absolute;inset:0;width:100%;height:100%;z-index:2;transform-origin:left;transition:transform 1.2s cubic-bezier(0.4,0,0.2,1);transform-style:preserve-3d;}
        .folder-container.open .folder-cover{transform:rotateY(-175deg);}
        .cover-front{position:absolute;inset:0;backface-visibility:hidden;background:var(--gold-pale);border:1px solid var(--gold);border-radius:10px;display:flex;align-items:center;justify-content:center;box-shadow:6px 8px 30px rgba(0,0,0,.1);}
        .cover-design{width:88%;height:92%;border:1px solid rgba(201,168,76,.4);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;position:relative;}
        .cover-design::before,.cover-design::after{content:'';position:absolute;width:18px;height:18px;border-color:var(--gold);border-style:solid;opacity:.6;}
        .cover-design::before{top:12px;left:12px;border-width:1px 0 0 1px;}
        .cover-design::after {bottom:12px;right:12px;border-width:0 1px 1px 0;}
        .cover-design h2{font-family:'Cormorant Garamond',serif;font-style:italic;color:var(--gold);font-size:clamp(1.6rem,5vw,2.4rem);}
        .cover-hint{font-size:clamp(.5rem,.5vw,.58rem);letter-spacing:.32em;color:var(--muted);text-transform:uppercase;}
        .cover-back{position:absolute;inset:0;backface-visibility:hidden;transform:rotateY(180deg);background:var(--white);border:1px solid var(--gold);border-radius:10px;padding:10px;display:flex;align-items:center;justify-content:center;overflow:hidden;}
        .cover-back img{width:100%;height:100%;object-fit:cover;border-radius:6px;transform:scaleX(-1);}
        .folder-inside{position:absolute;inset:0;background:var(--white);border:1px solid var(--line);border-radius:10px;z-index:1;display:flex;flex-direction:column;justify-content:center;padding:clamp(2rem,5vw,50px) clamp(1.5rem,5vw,38px);text-align:center;overflow-y:auto;}
        .inner-text h3{font-family:'Cormorant Garamond',serif;font-size:clamp(1.4rem,4vw,1.85rem);color:var(--gold);margin-bottom:clamp(1rem,3vw,22px);}
        .inner-text p {font-family:'Cormorant Garamond',serif;font-size:clamp(1rem,3vw,1.25rem);line-height:1.75;margin-bottom:10px;color:var(--ink);}
        .inner-text .sig{margin-top:clamp(1rem,3vw,24px);font-style:italic;color:var(--muted);font-size:clamp(.75rem,.5vw,.88rem);}

        /* gold particles - reduced on mobile */
        .pt{position:fixed;width:2px;height:2px;border-radius:50%;background:var(--gold);pointer-events:none;z-index:10;animation:drift var(--d) var(--dl) infinite;}
        @keyframes drift{0%{opacity:0;transform:translateY(100vh) translateX(0)}20%{opacity:.35}100%{opacity:0;transform:translateY(-10vh) translateX(var(--sx,0px))}}

        /* Photo Modal */
        .photo-modal{
            position:fixed;inset:0;z-index:600;background:rgba(0,0,0,0.85);
            display:flex;align-items:center;justify-content:center;
            opacity:0;visibility:hidden;transition:opacity .4s ease,visibility .4s ease;
            padding:1rem;
        }
        .photo-modal.show{opacity:1;visibility:visible;}
        .modal-content{position:relative;max-width:95vw;max-height:95vh;border-radius:12px;overflow:hidden;background:var(--white);box-shadow:0 20px 60px rgba(0,0,0,.4);}
        .modal-img{width:100%;height:100%;object-fit:contain;display:block;max-height:85vh;}
        .modal-close{
            position:absolute;top:12px;right:12px;width:40px;height:40px;
            background:rgba(0,0,0,0.6);color:var(--white);border:none;
            border-radius:50%;font-size:1.5rem;cursor:pointer;
            display:flex;align-items:center;justify-content:center;
            z-index:10;transition:background .3s;
        }
        .modal-close:hover{background:rgba(0,0,0,0.8);}
        .modal-close:active{transform:scale(0.95);}

        /* View Photo Button */
        .view-photo-btn{
            margin-top:clamp(1rem,3vw,1.5rem);padding:0.8rem 1.6rem;
            background:linear-gradient(135deg,var(--gold),var(--gold-light));
            color:var(--white);border:none;border-radius:6px;
            font-family:'Jost',sans-serif;font-size:clamp(.85rem,.5vw,1rem);
            cursor:pointer;letter-spacing:.08em;
            transition:transform .3s,box-shadow .3s;
            box-shadow:0 4px 15px rgba(201,168,76,0.3);
        }
        .view-photo-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(201,168,76,0.5);}
        .view-photo-btn:active{transform:translateY(0);}

        @media (max-width: 480px) {
            .view-photo-btn{padding:0.7rem 1.4rem;font-size:.8rem;}
            .modal-close{width:36px;height:36px;font-size:1.3rem;}
        }

        /* Mobile optimization */
        @media (max-width: 768px) {
            .balloon svg {
                width: clamp(32px, 8vw, 46px);
                height: auto;
            }
            .folder-container {
                height: clamp(320px, 80vw, 500px);
            }
        }

        @media (max-width: 480px) {
            .folder-container {
                height: clamp(300px, 90vw, 450px);
            }
            .divider-ornament span {
                max-width: 50px;
            }
        }

        /* Disable animations on low-power devices */
        @media (prefers-reduced-motion: reduce) {
            * {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body>

<!-- ══ SPLASH ══ -->
<div id="splash">
    <svg id="cake-svg" viewBox="0 0 160 160" fill="none">
        <g class="plate"><ellipse cx="80" cy="138" rx="58" ry="10" fill="#EDE4CE" stroke="#C9A84C"/></g>
        <g class="layer-bot"><rect x="28" y="106" width="104" height="34" rx="6" fill="#F5EDD6" stroke="#C9A84C"/></g>
        <g class="layer-mid"><rect x="38" y="76" width="84" height="32" rx="5" fill="#FDF6E3" stroke="#C9A84C"/></g>
        <g class="layer-top"><rect x="50" y="50" width="60" height="28" rx="5" fill="#FFFCF0" stroke="#C9A84C"/></g>
        <g class="candle">
            <rect x="71" y="36" width="6" height="16" rx="2" fill="#C9A84C"/>
            <rect x="85" y="32" width="6" height="20" rx="2" fill="#C9A84C"/>
        </g>
        <g class="flame" style="animation:flameIn .4s 1.3s forwards,flicker 1.2s 1.7s infinite">
            <ellipse cx="74" cy="32" rx="3.5" ry="5" fill="#FFD93D"/>
            <ellipse cx="88" cy="28" rx="3.5" ry="5" fill="#FFD93D"/>
        </g>
    </svg>
    <p class="splash-title">Happy Birthday</p>
    <p class="splash-sub">A celebration just for you</p>
    <button class="splash-enter" onclick="enterSite()">Enter &nbsp;✦</button>
</div>

<!-- ══ STAGE 1: FIREWORK SHOW ══ -->
<div id="fw-stage">
    <canvas id="fireworks-canvas"></canvas>
    <div id="fw-message">
        <div class="fw-line line-1" id="fwl1">Happy Birthday</div>
        <div class="fw-line line-2" id="fwl2">To The Beautiful Girl</div>
        <div class="fw-line line-3" id="fwl3">My Eyes</div>
        <div class="fw-line line-4" id="fwl4">Have Ever Seen</div>
    </div>
</div>

<!-- ══ BALLOONS ══ -->
<div class="balloons-layer" id="balloons-layer"></div>

<!-- ══ STAGE 2: MAIN CONTENT ══ -->
<div id="main">
    <div class="top-rule"></div>
    <div class="hero">
        <h1>Happy <em>Birthday</em></h1>
        <div class="divider-ornament"><span></span>✦<span></span></div>
        <p class="hero-sub">Wishing you a day as beautiful as you are</p>
    </div>
    <section class="card-section">
        <div class="folder-container" onclick="toggleFolder(this)">
            <div class="folder-cover">
                <div class="cover-front">
                    <div class="cover-design">
                        <h2>Maloka ❤️</h2>
                        <div class="divider-ornament" style="opacity:.4;margin:4px 0"><span></span>✦<span></span></div>
                        <p class="cover-hint">Tap to open</p>
                    </div>
                </div>
                <div class="cover-back">
                    <img src="https://i.ibb.co/yntgDZJM/photo-5785076706266779394-y.jpg" alt="Maloka" loading="lazy"/>
                </div>
            </div>
            <div class="folder-inside">
                <div class="inner-text">
                    <h3>To My Maloka... ❤️</h3>
                    <p>Kol sana w entii tayebaa ya malookaaa 🎂</p>
                    <p><em>Sana sa3eda 3alekii yarb</em></p>
                    <p>Wish you all happiness and everything your heart desires.</p>
                    <p>I wish you a year that carries everything you dream of — endless happiness, endless light.</p>
                    <p>Every year you are the most beautiful, the kindest.</p>
                    <p class="sig">— Always by your side ✦</p>
                </div>
                <button class="view-photo-btn" onclick="showPhotoModal()">View Photo 📸</button>
            </div>
        </div>
    </section>

    <!-- Photo Modal for Mobile -->
    <div id="photo-modal" class="photo-modal" onclick="closePhotoModal()">
        <div class="modal-content" onclick="event.stopPropagation()">
            <button class="modal-close" onclick="closePhotoModal()">✕</button>
            <img src="https://i.ibb.co/yntgDZJM/photo-5785076706266779394-y.jpg" alt="Maloka" class="modal-img"/>
        </div>
    </div>
</div>

<script>
    // Detect if device is mobile/low-power
    const isMobile = window.innerWidth <= 768;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ════════════════════════════
       GOLD PARTICLES (reduced on mobile)
    ════════════════════════════ */
    const particleCount = isMobile ? 6 : 14;
    for (let i = 0; i < particleCount; i++) {
        const p = document.createElement('div');
        p.className = 'pt';
        p.style.cssText = `left:${Math.random()*100}%;--d:${12+Math.random()*10}s;--dl:${Math.random()*8}s;--sx:${(Math.random()-.5)*60}px`;
        document.body.appendChild(p);
    }

    /* ════════════════════════════
       BALLOONS (reduced on mobile)
    ════════════════════════════ */
    const BC = [['#E8607A','#C9354F'],['#C9A84C','#A07830'],['#7EB8D4','#4A8FAB'],['#B07EC9','#8050A8'],['#7EC97E','#4A9A4A'],['#E8A060','#C07030']];
    const balloonCount = isMobile ? 6 : 10;

    function buildBalloons() {
        const layer = document.getElementById('balloons-layer');
        for (let i = 0; i < balloonCount; i++) {
            const [f,s] = BC[i%BC.length];
            const el = document.createElement('div');
            el.className = 'balloon';
            const sway = (Math.random()>.5?1:-1)*(20+Math.random()*50);
            el.style.cssText = `left:${5+Math.random()*88}%;--dur:${14+Math.random()*10}s;--dl:${i*1.8+Math.random()*2}s;--sway:${sway}px`;
            el.innerHTML = `<svg width="46" height="72" viewBox="0 0 46 72" fill="none">
              <ellipse cx="23" cy="26" rx="21" ry="24" fill="${f}"/>
              <ellipse cx="17" cy="14" rx="5" ry="7" fill="${s}" opacity="0.25"/>
              <polygon points="21,50 25,50 23,56" fill="${s}" opacity="0.7"/>
              <line x1="23" y1="56" x2="21" y2="72" stroke="${s}" stroke-width="1.2" stroke-linecap="round" stroke-dasharray="2 3"/>
            </svg>`;
            layer.appendChild(el);
        }
    }

    /* ════════════════════════════
       FIREWORKS ENGINE (optimized)
    ════════════════════════════ */
    const canvas = document.getElementById('fireworks-canvas');
    const ctx    = canvas.getContext('2d');
    function resize(){ canvas.width=window.innerWidth; canvas.height=window.innerHeight; }
    resize(); window.addEventListener('resize', resize);

    let fwActive=false, raf, fc=0;
    let rockets=[], parts=[];
    const FC=['#C9A84C','#E8C97A','#FFD93D','#E87070','#B07EC9','#7EB8D4','#ffffff','#F5EDD6'];
    const sparkCount = isMobile ? 60 : 100;

    class Rocket {
        constructor(){
            this.x=80+Math.random()*(canvas.width-160); this.y=canvas.height;
            this.tx=80+Math.random()*(canvas.width-160);
            this.ty=canvas.height*.08+Math.random()*canvas.height*.42;
            const a=Math.atan2(this.ty-this.y,this.tx-this.x), sp=8+Math.random()*5;
            this.vx=Math.cos(a)*sp; this.vy=Math.sin(a)*sp;
            this.trail=[]; this.done=false;
        }
        update(){
            this.trail.push({x:this.x,y:this.y});
            if(this.trail.length>10) this.trail.shift();
            this.x+=this.vx; this.y+=this.vy; this.vy+=0.08;
            if(this.vy>=0||this.y<=this.ty){ this.explode(); this.done=true; }
        }
        explode(){
            const col=FC[Math.floor(Math.random()*FC.length)];
            for(let i=0;i<sparkCount;i++){
                const a=(Math.PI*2*i)/sparkCount+Math.random()*.3, sp=1.5+Math.random()*4;
                parts.push(new Spark(this.x,this.y,Math.cos(a)*sp,Math.sin(a)*sp,col));
            }
        }
        draw(){
            ctx.beginPath();
            this.trail.forEach((p,i)=>{
                ctx.globalAlpha=(i/this.trail.length)*.7;
                i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y);
            });
            ctx.strokeStyle='#fff'; ctx.lineWidth=1.6; ctx.stroke(); ctx.globalAlpha=1;
        }
    }
    class Spark {
        constructor(x,y,vx,vy,col){this.x=x;this.y=y;this.vx=vx;this.vy=vy;this.col=col;this.a=1;this.r=1.2+Math.random()*1.8;this.d=.011+Math.random()*.011;}
        update(){this.x+=this.vx;this.y+=this.vy;this.vy+=.06;this.vx*=.98;this.a-=this.d;}
        draw(){ctx.globalAlpha=Math.max(0,this.a);ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fillStyle=this.col;ctx.fill();ctx.globalAlpha=1;}
    }

    function fwLoop(){
        if(!fwActive) return;
        raf=requestAnimationFrame(fwLoop);
        ctx.clearRect(0,0,canvas.width,canvas.height);
        ctx.fillStyle='rgba(250,250,248,0.07)';
        ctx.fillRect(0,0,canvas.width,canvas.height);
        fc++;
        if(fc%70===0) rockets.push(new Rocket());
        rockets=rockets.filter(r=>{if(!r.done){r.update();r.draw();}return !r.done;});
        parts  =parts.filter(p=>{p.update();if(p.a>0){p.draw();return true;}return false;});
    }

    function showLine(id, durMs){
        const el=document.getElementById(id);
        el.style.animation='none';
        el.getBoundingClientRect();
        el.style.animation=`fwIn ${durMs}ms ease forwards`;
    }

    /* ════════════════════════════
       SEQUENCE TIMINGS
    ════════════════════════════ */
    const SEQ = [
        {id:'fwl1', at:800,   dur:3800},
        {id:'fwl2', at:5200,  dur:3800},
        {id:'fwl3', at:9500,  dur:3500},
        {id:'fwl4', at:13500, dur:4000},
    ];
    const FW_TOTAL = 18500;
    const MAIN_DELAY = FW_TOTAL + 1200;

    function enterSite(){
        document.getElementById('splash').classList.add('hide');

        // Start fireworks engine
        fwActive=true; fc=0; fwLoop();

        // Launch rockets & show lines on schedule
        SEQ.forEach(({id,at,dur})=>{
            setTimeout(()=>rockets.push(new Rocket()), Math.max(0,at-700));
            setTimeout(()=>rockets.push(new Rocket()), Math.max(0,at-300));
            setTimeout(()=>{ showLine(id,dur); rockets.push(new Rocket()); }, at);
        });

        // Ambient rockets between phrases
        [300,2000,3800,7000,8500,11500,12500,16000,17500].forEach(t=>
            setTimeout(()=>rockets.push(new Rocket()), t)
        );

        // Stop fireworks engine, fade out stage
        setTimeout(()=>{
            fwActive=false;
            cancelAnimationFrame(raf);
            ctx.clearRect(0,0,canvas.width,canvas.height);
            document.getElementById('fw-stage').classList.add('hide');
        }, FW_TOTAL);

        // Reveal main content + balloons
        setTimeout(()=>{
            document.getElementById('main').classList.add('show');
            buildBalloons();
            setTimeout(()=> document.getElementById('balloons-layer').classList.add('show'), 300);
        }, MAIN_DELAY);
    }

    // Prevent pinch zoom interference on interactive elements
    document.addEventListener('touchmove', function(e) {
        if(e.scale !== 1) e.preventDefault();
    }, { passive: false });

    /* ════════════════════════════
       PHOTO MODAL FUNCTIONS
    ════════════════════════════ */
    function showPhotoModal() {
        const modal = document.getElementById('photo-modal');
        modal.classList.add('show');
        document.body.style.overflow = 'hidden';
    }

    function closePhotoModal() {
        const modal = document.getElementById('photo-modal');
        modal.classList.remove('show');
        document.body.style.overflow = 'auto';
    }

    // Close modal on Escape key
    document.addEventListener('keydown', (e) => {
        if(e.key === 'Escape') closePhotoModal();
    });

    /* ════════════════════════════
       FOLDER TOGGLE FUNCTION
    ════════════════════════════ */
    function toggleFolder(element) {
        element.classList.toggle('open');
    }
</script>
